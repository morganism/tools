#!/usr/bin/env bash
###############################################################################
# download_cmdb_assets.sh
# S3 Object downloader with MRU state (bucket, prefix, profile, selection)
###############################################################################
set -uo pipefail

readonly MRU_FILE="${HOME}/.download_cmdb_assets.mru"
readonly LOGFILE="${HOME}/downloadCMDB_Assets.$(date +%Y%m%d-%H%M%S).log"
START_TIME=$(date +%s)

# ANSI
readonly Reset="\033[0m" Bold="\033[1m"
readonly Red="\033[31m" Green="\033[32m" Yellow="\033[33m" Blue="\033[34m" White="\033[37m" Cyan="\033[36m"
readonly Clear="\033[2J" Home="\033[H" Hide="\033[?25l" Show="\033[?25h"
readonly Tick="✔" Cross="✘" Box="☐" Checked="☑"

AWS_PROFILE_NAME=""
BUCKET=""
PREFIX=""
DEST_DIR=""
declare -a FILES
declare -a SELECTED

log() { printf "[%(%F %T)T] %s\n" -1 "$*" >>"$LOGFILE"; }

run() {
    log "COMMAND: $*"
    local OUTPUT RC
    OUTPUT="$("$@" 2>&1)"
    RC=$?
    log "$OUTPUT"
    log "RETURN=$RC"
    printf "%s" "$OUTPUT"
    return $RC
}

cleanup() { printf "${Show}${Reset}"; }
trap cleanup EXIT

###############################################################################
# MRU state
###############################################################################
load_mru() {
    [[ -f "$MRU_FILE" ]] || return 0
    # shellcheck disable=SC1090
    source "$MRU_FILE"
    AWS_PROFILE_NAME="${MRU_PROFILE:-}"
    BUCKET="${MRU_BUCKET:-}"
    PREFIX="${MRU_PREFIX:-}"
    DEST_DIR="${MRU_DEST_DIR:-}"
}

save_mru() {
    local selected_files=""
    local i
    for ((i=0;i<${#FILES[@]};i++)); do
        (( SELECTED[i] )) && selected_files+="${FILES[i]}"$'\n'
    done

    cat >"$MRU_FILE" <<EOF
MRU_PROFILE=$(printf '%q' "$AWS_PROFILE_NAME")
MRU_BUCKET=$(printf '%q' "$BUCKET")
MRU_PREFIX=$(printf '%q' "$PREFIX")
MRU_DEST_DIR=$(printf '%q' "$DEST_DIR")
MRU_LAST_SELECTION=$(printf '%q' "$selected_files")
EOF
}

###############################################################################
# Prompts
###############################################################################
prompt_config() {
    printf "${Bold}${Cyan}"
    printf "┌────────────────────────────────────────────────────────────┐\n"
    printf "│                  CMDB Asset Downloader                     │\n"
    printf "└────────────────────────────────────────────────────────────┘\n"
    printf "${Reset}\n"

    read -rp "AWS profile [${AWS_PROFILE_NAME:-default}]: " input
    AWS_PROFILE_NAME="${input:-${AWS_PROFILE_NAME:-default}}"

    read -rp "S3 bucket [${BUCKET:-cmdb-trade-tariff-382373577178}]: " input
    BUCKET="${input:-${BUCKET:-cmdb-trade-tariff-382373577178}}"

    read -rp "S3 prefix/folder [${PREFIX:-HMRC-2388/}]: " input
    PREFIX="${input:-${PREFIX:-HMRC-2388/}}"
    [[ "$PREFIX" == */ || -z "$PREFIX" ]] || PREFIX="${PREFIX}/"

    read -rp "Destination directory [${DEST_DIR:-./${PREFIX%/}}]: " input
    DEST_DIR="${input:-${DEST_DIR:-./${PREFIX%/}}}"

    printf "\n"
}

###############################################################################
# AWS validation
###############################################################################
validate_aws_auth() {
    printf "${Yellow}Checking AWS authentication (profile: %s)...${Reset}\n" "$AWS_PROFILE_NAME"

    if ! run aws sts get-caller-identity --profile "$AWS_PROFILE_NAME" >/dev/null
    then
        printf "\n${Red}${Cross} AWS CLI is not authenticated${Reset}\n"
        printf "Log: %s\n" "$LOGFILE"
        return 1
    fi

    printf "${Green}${Tick} AWS Authentication OK${Reset}\n\n"
}

###############################################################################
# List objects
###############################################################################
list_objects() {
    local s3_uri="s3://${BUCKET}/${PREFIX}"
    local list

    printf "${Yellow}Retrieving object list from %s...${Reset}\n" "$s3_uri"

    if ! list=$(run aws s3 ls "$s3_uri" --recursive --profile "$AWS_PROFILE_NAME")
    then
        printf "${Red}Unable to list bucket${Reset}\n"
        return 1
    fi

    mapfile -t FILES < <(printf "%s\n" "$list" | awk '{print $4}')

    if (( ${#FILES[@]} == 0 ))
    then
        printf "${Red}No files found.${Reset}\n"
        return 1
    fi
}

###############################################################################
# Checkbox menu
###############################################################################
select_objects() {
    local count=${#FILES[@]}
    local cursor=0
    local i key

    for ((i=0;i<count;i++)); do SELECTED[$i]=0; done

    printf "${Hide}"

    while true
    do
        printf "${Clear}${Home}"
        printf "${Bold}${Cyan}CMDB Asset Downloader${Reset}\n\n"
        printf "Use:\n  ↑ ↓  Move\n  SPACE Toggle\n  a     Select All\n  n     None\n  ENTER Download\n  q     Quit\n\n"

        for ((i=0;i<count;i++))
        do
            if (( cursor==i )); then printf "${Blue}> ${Reset}"; else printf "  "; fi
            if (( SELECTED[i] )); then printf "${Green}${Checked}${Reset} "; else printf "${White}${Box}${Reset} "; fi
            printf "%s\n" "${FILES[i]}"
        done

        IFS= read -rsn1 key

        case "$key" in
            "") break ;;
            " ")
                if (( SELECTED[cursor] )); then SELECTED[cursor]=0; else SELECTED[cursor]=1; fi
                ;;
            a) for ((i=0;i<count;i++)); do SELECTED[i]=1; done ;;
            n) for ((i=0;i<count;i++)); do SELECTED[i]=0; done ;;
            q) printf "\nCancelled\n"; printf "${Show}"; return 1 ;;
            $'\x1b')
                read -rsn2 key
                case "$key" in
                    "[A") ((cursor--)) ;;
                    "[B") ((cursor++)) ;;
                esac
                ((cursor<0)) && cursor=0
                ((cursor>=count)) && cursor=$((count-1))
                ;;
        esac
    done

    printf "${Show}"
}

###############################################################################
# Download
###############################################################################
download_selected() {
    printf "${Clear}${Home}"
    printf "${Bold}${Green}Downloading selected assets...${Reset}\n\n"

    local downloaded=0 failed=0 i file

    mkdir -p "$DEST_DIR"

    for ((i=0;i<${#FILES[@]};i++))
    do
        (( SELECTED[i] )) || continue
        file="${FILES[i]}"

        printf "${Yellow}Downloading %s...${Reset}\n" "$file"

        if run aws s3 cp "s3://${BUCKET}/${file}" "${DEST_DIR}/$(basename "$file")" --profile "$AWS_PROFILE_NAME"
        then
            ((downloaded++))
            printf "${Green}${Tick}${Reset}\n"
        else
            ((failed++))
            printf "${Red}${Cross}${Reset}\n"
        fi
        printf "\n"
    done

    print_summary "$downloaded" "$failed"
}

print_summary() {
    local downloaded=$1 failed=$2
    local end elapsed
    end=$(date +%s)
    elapsed=$((end-START_TIME))

    printf "\n${Bold}${Cyan}"
    printf "┌─────────────────────────────────────────────────────┐\n"
    printf "│                     Summary                         │\n"
    printf "├─────────────────────────────────────────────────────┤\n"
    printf "│ Downloaded : %-36d│\n" "$downloaded"
    printf "│ Failed      : %-36d│\n" "$failed"
    printf "│ Duration    : %-36ds│\n" "$elapsed"
    printf "└─────────────────────────────────────────────────────┘\n"
    printf "${Reset}\n"

    printf "${Green}Log file:${Reset}\n  %s\n\n" "$LOGFILE"
}

###############################################################################
# Main
###############################################################################
main() {
    load_mru
    prompt_config

    validate_aws_auth || exit 1
    list_objects || exit 1
    select_objects || { save_mru; exit 0; }
    download_selected
    save_mru
}

main "$@"
