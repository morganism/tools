alias shutdown="sudo shutdown -r now"
alias cv='pushd ~/src/morganism/cv'
alias uuidgen3=uuidgen
alias awsp='[[ -f "$HOME/bin/aws-profile-select.sh" ]] \
  && source "$HOME/bin/aws-profile-select.sh" \
  || printf "\033[0;31mFile [%s] not found.\033[0m\n" "$HOME/bin/aws-profile-select.sh"'
alias awsexp='aws configure export-credentials --profile 844815912454_TariffAdministratorAccess --format env'
alias j='z'
alias init.morganism.dev='$(curl -sL https://init.morganism.dev | grep curl | sed -e 's:^.*curl:curl:' -e 's:bash.*$:bash:' |tail -1) | bash'
alias copycat='cpcat '
