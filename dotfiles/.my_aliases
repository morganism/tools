alias init='source ~/.init'
alias dcud='docker compose up -d'
alias ll='ls -liastr'
alias ll2='ls -liastre@'
# Mimic Linux 'ip' command on macOS
alias ip='ifconfig'                       # `ip a` → network interfaces
alias ipa='ifconfig'                      # shorthand for `ip a`
alias ipr='netstat -nr'                   # `ip r` → routing table
alias ipn='networksetup -listallhardwareports'  # shows interface names and MACs
alias awsprofile='source ~/bin/_awsconsole'

alias awssel='export AWS_PROFILE=$(cat ~/.config/aws/selected_profile)' 
# sourcing
alias sbp='source ~/.bash_profile && source ~/.my_bash_profile'
alias smf='source ~/.my_functions'
alias sma='source ~/.my_aliases'
alias prod='source /Users/morgan/bin/_prodprofile'
alias dev='source /Users/morgan/bin/_devprofile'
# editing
alias vbrc='vi ~/.bashrc && source ~/.bashrc'
alias cdm='pushd ~/src/morganism'
alias cds='pushd ~/src'
alias cdt='pushd /tmp/'
alias vma='vi_my_aliases'
alias vmf='vi_my_functions'
alias vbp="vi ~/.my_bash_profile && echo -e \"\n\n ${IRed}Remember ${Red}source *my* bash profile !${Reset} [${IBlack}~/.my_bash_profile${Reset}] ${IWhite}sbp ${Reset}\n\n\""
# cd to
alias cds='pushd ~/src'
alias cdm='pushd ~/src/morganism'
alias cdt='pushd ~/src/morganism/tools'
alias tmp='pushd ~/tmp'
alias tools='pushd ~/src/morganism/tools'
alias runvnc="vncserver -xstartup $HOME/bin/xstartup"
alias ghowner='gh auth status|grep Logged|sed -e '\''s:^.*account ::'\'' -e '\''s: .*$::'\'''
alias goaws='select_aws_profile.sh && awssel'
# from deleted ~/.aws_aliases
alias downl='pushd ~/Downloads'
