THIS="$(realpath $BASH_SOURCE)"
DIR="$(dirname $THIS)"

LIB_COLOURS=".ansi.functions"
[[ -f "${DIR}/${LIB_COLOURS}" ]] && source "${DIR}/${LIB_COLOURS}"

alias dcud='docker compose up -d'
alias ll='ls -liastr'
alias ll2='ls -liastre@'
# Mimic Linux 'ip' command on macOS
alias ip='ifconfig'                       # `ip a` → network interfaces
alias ipa='ifconfig'                      # shorthand for `ip a`
alias ipr='netstat -nr'                   # `ip r` → routing table
alias ipn='networksetup -listallhardwareports'  # shows interface names and MACs
alias awsprofile='source ~/bin/_awsconsole'
alias awssel='export AWS_PROFILE=$(cat ~/.config/aws/selected_profile)' 
alias sbp='source ~/.bash_profile && source ~/.my_bash_profile'
alias vbp="vi ~/.my_bash_profile && echo -e \"\n\n ${IRed}Remember ${Red}source *my* bash profile !${Reset} [${IBlack}~/.my_bash_profile${Reset}] ${IWhite}sbp ${Reset}\n\n\""
alias vma='vi_my_aliases'
alias vmf='vi_my_functions'
alias smf='source ~/.my_functions'
alias sma='source ~/.my_aliases'
alias vbrc='vi ~/.bashrc && source ~/.bashrc'
alias cdm='pushd ~/src/morganism'
alias cds='pushd ~/src'
alias cdt='pushd /tmp/'
alias tools='pushd ~/src/morganism/tools'
alias ggu='git config --local --get remote.origin.url' # ggu == git get url : the url that you clone
alias runvnc="vncserver -xstartup $HOME/bin/xstartup"
alias ghowner='gh auth status|grep Logged|sed -e '\''s:^.*account ::'\'' -e '\''s: .*$::'\'''
alias goaws='select_aws_profile.sh && awssel'
# from deleted ~/.aws_aliases
alias prod='source /Users/morgan/bin/_prodprofile'
alias dev='source /Users/morgan/bin/_devprofile'
alias downl='pushd ~/Downloads'
alias gita='git add'
alias gitc='git commit'
alias gitcm='git commit -m '
alias gitp='git push'
alias dg='doc_generator'
alias thanksgiving='date -v1d -v+9m -v-1d -v-thu -j'
alias gits='git status'
alias disablewebcam='sudo modprobe -r uvcvideo'
alias gitadder="git status | grep modified | sed -e 's/^.modified:   //' | tee >(xargs git add)"
alias gitstaged="git status --short | grep '^M[ M] ' | sed -e 's/^...//'"
alias gitnotstaged="git status --short | grep '^[ M]M ' | sed -e 's/^...//' | tr '\n' ' '"
alias gitaddnotstaged="gitnotstaged && echo -e \"${Yellow}In 3s ...${Reset}\" && for i in \"$(gitnotstaged)\"; do echo \"git add $i\"; git add $i; done"
alias gitadded="git status --short | grep '^MM ' | sed -e 's:^MM *::'"
alias gitnotadded="git status --short | grep '^M ' | sed -e 's:^M *::'"
alias shutdown="sudo shutdown -r now"
alias cv='pushd ~/src/morganism/cv'
alias uuidgen3=uuidgen
alias accesstoken='curl --request POST "https://auth.id.trade-tariff.service.gov.uk/oauth2/token" \
  -H "Content-Type: application/x-www-form-urlencoded" \
  -d "grant_type=client_credentials&client_id=3voa8r5jfdt5sqv41es64jn8f2&client_secret=14d4t51v211j8s20ppv984sd2i90js4fs985vujo6v73qg7jo9h5"'
