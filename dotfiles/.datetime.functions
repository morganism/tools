#!/bin/bash
.datetime.functions() {
  grep '()'  $BASH_SOURCE |  grep -v ".datetime.functions" | grep -v grep 
}

THIS="$(realpath $BASH_SOURCE)"
DIR="$(dirname $THIS)"

# -------------- TIMESTAMP
ts_rfc3339() {
  # macOS warning: macOS date has no %N or nanoseconds. )
  # Using EPOCHREALTIME means no dependency on BSD/GNU date → maximum portability. )
  printf '%(%Y-%m-%dT%H:%M:%S)T.%09dZ\n' "$EPOCHSECONDS" "${EPOCHREALTIME#*.}"
}

ts() {
  TS=$(ts_rfc3339)
  echo $TS
}

