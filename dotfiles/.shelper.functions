#!/bin/bash
.shelper.functions() {
  grep '()'  $BASH_SOURCE |  grep -v ".shelper.functions" | grep -v grep 
}

THIS="$(realpath $BASH_SOURCE)"
DIR="$(dirname $THIS)"

LIB_COLOURS=".ansi_colours.env"
LIB_DATETIME=".datetime.functions"
LIB_LOGGING=".logging.functions"
[[ -f "${DIR}/${LIB_COLOURS}" ]] && source "${DIR}/${LIB_COLOURS}"
[[ -f "${DIR}/${LIB_DATETIME}" ]] && source "${DIR}/${LIB_DATETIME}"
[[ -f "${DIR}/${LIB_LOGGING}" ]] && source "${DIR}/${LIB_LOGGING}"


