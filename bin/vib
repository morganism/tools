#!/usr/bin/env bash
: <<DOCXX

________________________________________________________________________________
Usage   : $0 OPTIONS
        :
Desc    : Things what I do
Author  : @author
Date    : @date 
________________________________________________________________________________
DOCXX

[[ -f .ansi.colours ]] && source .ansi.colours

echo -e "${Blue}N.B. ${White}vi${Blue} is aliased to ${IBlue}${0}${NC}"
echo -e "${Blue}here: ${IBlue}$(THIS_DIR)${NC}"
sleep 1

usage() {
    echo -e "${Grey_4}${On_Grey_16}Missing filename.\nUsage: $(basename $0) [-b] file${Reset}"
    echo -e "${Grey_4}${On_Grey_16}  where -b FILE .. Create FILE in $HOME/bin${Reset}"
}

dash() {
  # return some '-' chars (default 80)
  n=${1:-80} # how many?
  head -c $n < /dev/zero | tr '\0' '\101'
}

create_or_edit() {
    if [[ -z "$1" ]]; then
        echo -e "${Grey_4}${On_Grey_16}no FILE passed to create_or_edit function${Reset}"
        exit 3
    fi 

    if [[ -f "$HOME/.vib" ]]; then
        source $HOME/.vib   # source default settings file
    fi
    if [[ -f ".vib" ]]; then
        source .vib   # source default settings file
    fi
    RP=$(realpath $1)
    echo -e "${Grey_4}${On_Grey_16}realpath to '$1' is: $RP${Reset}"    

    SNIPPETS="~/.my_snippets"
    if [[ ! -e $1 ]]; then
      echo '#!/usr/bin/env bash' >> $1
      echo -e "${Grey_4}${On_Grey_16}: <<DOCXX${Reset}"           >> $1
      echo -e "${Grey_4}${On_Grey_16}Add description${Reset}"     >> $1
      echo -e "${Grey_4}${On_Grey_16}Author: $AUTHOR${Reset}"     >> $1
      echo -e "${Grey_4}${On_Grey_16}Date: $(date)${Reset}"       >> $1
      echo -e "${Grey_4}${On_Grey_16}DOCXX${Reset}"               >> $1
      echo ""                    >> $1
    fi
    touch                           $1
    chmod 755                       $1
    vi                              $1
    exit
}

if [[ -z $1 ]]; then
    usage
    exit 1   
elif [[ $1 =~ ^-h ]]; then
    usage
    exit 1
elif [[ "$1" =~ ^-b ]]; then
    shift

    if [[ -z $1 ]]; then
        echo -e "${Grey_4}${On_Grey_16}-b flag but no FILE ¿¿${Reset}"

        usage
        exit 2   
    fi
    echo -e "${Grey_4}${On_Grey_16}Creating new file in $HOME/bin/$1${Reset}"
    create_or_edit "$HOME/bin/$1"
fi

DIR="$HOME/bin"
if [[ -f $DIR/$1 ]]; then
    create_or_edit "$DIR/$1" ;
    exit
else
    if [[ -f $1 ]]; then
        create_or_edit "$1" ;
        exit
    else
       echo -e "${Grey_4}${On_Grey_16}no bin no exist file so create${Reset}"
    fi
fi
echo $1
create_or_edit $1
